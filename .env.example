# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored so your secrets stay local.
#
# Gemini API key — https://aistudio.google.com/apikey
# Used by the Chrome extension's "Generate Thumbnail" action
# (baked into the extension bundle at build time via Vite).
VITE_GEMINI_API_KEY=

# Optional: override the image model. Defaults to `gemini-3-pro-image-preview`
# (aka Nano Banana Pro) — 4K output, up to ~14 reference images, "thinking"
# composition refinement, strongest negative-instruction adherence. Cheaper:
#   gemini-3.1-flash-image-preview  — fast, 4K, ~$0.067/1K image
#   gemini-2.5-flash-image          — Nano Banana, 1024px max, 3 refs, ~$0.039/image
# VITE_GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
